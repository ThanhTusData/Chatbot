{
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "graph",
      "title": "Request rate",
      "targets": [
        { "expr": "sum(rate(app_requests_total[1m])) by (endpoint)", "legendFormat": "{{endpoint}}" }
      ]
    },
    {
      "type": "graph",
      "title": "Request latency (p50/p95)",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(app_request_latency_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "p95 {{endpoint}}" }
      ]
    },
    {
      "type": "graph",
      "title": "Inference time (avg)",
      "targets": [
        { "expr": "rate(inference_time_seconds_sum[1m]) / rate(inference_time_seconds_count[1m])", "legendFormat": "inference_avg" }
      ]
    }
  ],
  "title": "Intent Service Observability"
}
